---
import Screenshot from './Screenshot.astro';
import { t, type Lang } from '../i18n/strings';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="std" id="branch">
  <div class="frame">
    <div class="section-tag reveal">{t(lang, 'branch.tag')}</div>
    <h2 class="h-section section-h reveal">
      {t(lang, 'branch.h.before')}<span class="em">{t(lang, 'branch.h.em')}</span>
    </h2>
    <p class="section-lede reveal">{t(lang, 'branch.lede')}</p>
    <div class="branch-grid">
      <div class="branch-shot reveal">
        <Screenshot
          src="screenshots/node-mode.png"
          alt={t(lang, 'branch.shot.alt')}
          aspect="4/3"
          eager
        />
      </div>
      <ol class="scenarios reveal" aria-label={t(lang, 'branch.scenarios.aria')}>
        <li>
          <span class="step">01</span>
          <div class="body">
            <strong>{t(lang, 'branch.s1.strong')}</strong> {t(lang, 'branch.s1.body')}
          </div>
        </li>
        <li>
          <span class="step">02</span>
          <div class="body">
            <strong>{t(lang, 'branch.s2.strong')}</strong> {t(lang, 'branch.s2.body')}
          </div>
        </li>
        <li>
          <span class="step">03</span>
          <div class="body">
            <strong>{t(lang, 'branch.s3.strong')}</strong> {t(lang, 'branch.s3.body')}
          </div>
        </li>
      </ol>
    </div>
  </div>
</section>

<style>
  .branch-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .branch-shot {
    position: relative;
  }
  .branch-shot::before {
    content: '';
    position: absolute;
    inset: -10px -10px;
    background: radial-gradient(ellipse at 30% 50%, rgba(201, 111, 59, 0.08), transparent 70%);
    pointer-events: none;
    z-index: 0;
    border-radius: 16px;
  }
  .branch-shot :global(.screenshot) {
    position: relative;
    z-index: 1;
  }
  .scenarios {
    list-style: none;
    display: flex;
    flex-direction: column;
    margin: 0;
    padding: 0;
  }
  .scenarios li {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding: 20px 14px;
    margin: 0 -14px;
    border-bottom: 1px solid var(--line);
    border-radius: 8px;
    transition: background 220ms ease;
  }
  .scenarios li:hover {
    background: var(--panel);
  }
  .scenarios li:last-child { border-bottom: 0; }
  .scenarios .step {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    padding-top: 3px;
    min-width: 32px;
    letter-spacing: 0.08em;
  }
  .scenarios .body {
    color: var(--text-dim);
    font-size: 16px;
    line-height: 1.55;
  }
  .scenarios .body strong {
    color: var(--text);
    font-family: var(--font-display);
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .branch-grid { grid-template-columns: 1fr; gap: 32px; }
    .scenarios .body { font-size: 15px; }
  }
</style>
