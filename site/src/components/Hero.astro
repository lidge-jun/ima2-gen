---
import CodeCopy from './CodeCopy.astro';
import Screenshot from './Screenshot.astro';
import { t, type Lang } from '../i18n/strings';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const crossLangUrl =
  lang === 'en'
    ? 'https://github.com/lidge-jun/ima2-gen/blob/main/docs/README.ko.md'
    : 'https://lidge-jun.github.io/ima2-gen/?lang=en';
---

<section class="hero" id="top">
  <div class="frame hero-grid">
    <div class="hero-text reveal">
      <div class="eyebrow">{t(lang, 'hero.eyebrow')}</div>
      <h1 class="h-display" id="hero-h1" aria-describedby="hero-sub">
        {t(lang, 'hero.h1.line1')}<br />{t(lang, 'hero.h1.line2')}<br /><span class="em">{t(lang, 'hero.h1.em')}</span>
      </h1>
      <p class="sub" id="hero-sub">{t(lang, 'hero.sub')}</p>
      <CodeCopy command={t(lang, 'hero.cta.cmd')} />
      <a class="ko-link" href={crossLangUrl} target={lang === 'en' ? '_blank' : undefined} rel={lang === 'en' ? 'noopener' : undefined}>
        {t(lang, 'hero.cross.lang')}
      </a>
    </div>
    <div class="hero-shot reveal">
      <Screenshot
        src="screenshots/classic-generate-light.png"
        alt={t(lang, 'hero.shot.alt')}
        eager
      />
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 112px 0 96px;
    border-bottom: 1px solid var(--line);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .hero-text h1 {
    font-size: 88px;
    margin-bottom: 28px;
  }
  .hero-text .sub {
    font-size: 20px;
    color: var(--text-dim);
    max-width: 540px;
    margin-bottom: 36px;
    line-height: 1.55;
  }
  .ko-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-dim);
    border-bottom: 1px solid var(--line);
    padding-bottom: 4px;
    transition: color 160ms ease, border-color 160ms ease;
  }
  .ko-link:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  @media (max-width: 768px) {
    .hero { padding: 72px 0 64px; }
    .hero-grid { grid-template-columns: 1fr; gap: 32px; }
    .hero-text h1 { font-size: 56px; }
    .hero-text .sub { font-size: 18px; }
  }
</style>
