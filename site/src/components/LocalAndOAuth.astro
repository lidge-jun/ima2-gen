---
import Screenshot from './Screenshot.astro';
import { t, type Lang } from '../i18n/strings';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="std" id="local">
  <div class="frame">
    <div class="section-tag reveal">{t(lang, 'local.tag')}</div>
    <div class="local-grid">
      <div class="local-shot reveal">
        <Screenshot
          src="screenshots/settings-oauth-generation.png"
          alt={t(lang, 'local.shot.alt')}
          aspect="4/3"
          eager
        />
      </div>
      <div class="local-text reveal">
        <h2 class="h-section section-h">
          {t(lang, 'local.h.before')}<span class="em">{t(lang, 'local.h.em')}</span>
        </h2>
        <p class="section-lede">{t(lang, 'local.lede')}</p>
        <blockquote class="pull-quote">
          {t(lang, 'local.quote.before')}<strong>{t(lang, 'local.quote.strong')}</strong>{t(lang, 'local.quote.after')}
        </blockquote>
        <p class="local-meta">{t(lang, 'local.meta')}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .local-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: center;
  }
  .local-text .section-lede { margin-bottom: 28px; }
  .pull-quote {
    border-left: 2px solid var(--accent);
    padding: 6px 0 6px 18px;
    font-size: 17px;
    color: var(--text);
    font-family: var(--font-body);
    font-style: italic;
    margin: 0 0 22px 0;
    line-height: 1.5;
  }
  .pull-quote strong {
    color: var(--accent);
    font-style: normal;
    font-family: var(--font-display);
    font-weight: 600;
  }
  .local-meta {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-dim);
    margin: 0;
  }

  @media (max-width: 768px) {
    .local-grid { grid-template-columns: 1fr; gap: 32px; }
  }
</style>
