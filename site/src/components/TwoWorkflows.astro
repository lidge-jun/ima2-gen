---
import Screenshot from './Screenshot.astro';
import { t, type Lang } from '../i18n/strings';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="std" id="workflows">
  <div class="frame">
    <div class="section-tag reveal">{t(lang, 'workflows.tag')}</div>
    <h2 class="h-section section-h reveal">
      {t(lang, 'workflows.h.before')}<span class="em">{t(lang, 'workflows.h.em')}</span>
    </h2>
    <p class="section-lede reveal">{t(lang, 'workflows.lede')}</p>
    <div class="workflows-grid">
      <article class="workflow-card reveal">
        <Screenshot
          src="screenshots/classic-mode.png"
          alt={t(lang, 'workflows.classic.alt')}
          aspect="16/10"
          eager
        />
        <div class="workflow-meta">
          <div class="label">{t(lang, 'workflows.classic.label')}</div>
          <h3>{t(lang, 'workflows.classic.h')}</h3>
          <p>{t(lang, 'workflows.classic.body')}</p>
        </div>
      </article>
      <article class="workflow-card reveal">
        <Screenshot
          src="screenshots/node-graph-branching.png"
          alt={t(lang, 'workflows.node.alt')}
          aspect="16/10"
          eager
        />
        <div class="workflow-meta">
          <div class="label">{t(lang, 'workflows.node.label')}</div>
          <h3>{t(lang, 'workflows.node.h')}</h3>
          <p>{t(lang, 'workflows.node.body')}</p>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .workflows-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
  }
  .workflow-card {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 10px;
    overflow: hidden;
  }
  .workflow-card :global(.screenshot) {
    border: 0;
    border-bottom: 1px solid var(--line);
    border-radius: 0;
  }
  .workflow-meta { padding: 22px 22px 26px; }
  .workflow-meta .label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--accent);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .workflow-meta h3 {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: 10px;
  }
  .workflow-meta p {
    color: var(--text-dim);
    font-size: 15px;
  }

  @media (max-width: 768px) {
    .workflows-grid { grid-template-columns: 1fr; gap: 20px; }
    .workflow-meta h3 { font-size: 20px; }
  }
</style>
