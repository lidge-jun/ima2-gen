---
import Screenshot from './Screenshot.astro';
---

<section class="std" id="workflows">
  <div class="frame">
    <div class="section-tag reveal">01 · Two ways to make</div>
    <h2 class="h-section section-h reveal">
      Two ways to make. <span class="em">One way to branch.</span>
    </h2>
    <p class="section-lede reveal">
      Classic for one strong frame. Node for a tree of variations from a parent you locked
      in. Pick the workflow your idea wants.
    </p>
    <div class="workflows-grid">
      <article class="workflow-card reveal">
        <Screenshot
          src="screenshots/classic-mode.png"
          alt="ima2-gen Classic mode with prompt composer, references, and a generated team portrait."
          aspect="16/10"
          eager
        />
        <div class="workflow-meta">
          <div class="label">Classic</div>
          <h3>One prompt, one strong frame.</h3>
          <p>
            Write, attach up to five references, generate. Iterate until it lands. Continue
            from any result.
          </p>
        </div>
      </article>
      <article class="workflow-card reveal">
        <Screenshot
          src="screenshots/node-graph-branching.png"
          alt="ima2-gen Node mode with connected generated cards and per-node metadata."
          aspect="16/10"
          eager
        />
        <div class="workflow-meta">
          <div class="label">Node</div>
          <h3>One frame, ten directions.</h3>
          <p>
            Lock a parent. Fan out children — palette, framing, copy. Compare side by side.
            Never lose the original.
          </p>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .workflows-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
  }
  .workflow-card {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 10px;
    overflow: hidden;
  }
  .workflow-card :global(.screenshot) {
    border: 0;
    border-bottom: 1px solid var(--line);
    border-radius: 0;
  }
  .workflow-meta { padding: 22px 22px 26px; }
  .workflow-meta .label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--accent);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .workflow-meta h3 {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: 10px;
  }
  .workflow-meta p {
    color: var(--text-dim);
    font-size: 15px;
  }

  @media (max-width: 768px) {
    .workflows-grid { grid-template-columns: 1fr; gap: 20px; }
    .workflow-meta h3 { font-size: 20px; }
  }
</style>
