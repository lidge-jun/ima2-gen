---
import Screenshot from './Screenshot.astro';
import { t, type Lang } from '../i18n/strings';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const fields: string[] = [
  'style.field.medium',
  'style.field.composition',
  'style.field.mood',
  'style.field.subject',
  'style.field.palette',
  'style.field.negative',
];
---

<section class="std" id="style">
  <div class="frame">
    <div class="section-tag reveal">{t(lang, 'style.tag')}</div>
    <div class="style-grid">
      <div class="style-text reveal">
        <h2 class="h-section section-h">
          {t(lang, 'style.h.before')}<span class="em">{t(lang, 'style.h.em')}</span>
        </h2>
        <p class="section-lede">{t(lang, 'style.lede')}</p>
        <ul class="field-list">
          {fields.map((key) => <li>{t(lang, key)}</li>)}
        </ul>
      </div>
      <div class="style-shot reveal">
        <Screenshot
          src="screenshots/style-sheet-editor.png"
          alt={t(lang, 'style.shot.alt')}
          aspect="4/3"
          eager
        />
      </div>
    </div>
  </div>
</section>

<style>
  .style-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .style-text .section-lede { margin-bottom: 24px; }
  .field-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 0;
    margin: 0;
  }
  .field-list li {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--text-dim);
    display: flex;
    gap: 12px;
    align-items: center;
  }
  .field-list li::before {
    content: '';
    width: 6px;
    height: 6px;
    background: var(--accent);
    border-radius: 50%;
  }

  @media (max-width: 768px) {
    .style-grid { grid-template-columns: 1fr; gap: 32px; }
  }
</style>
