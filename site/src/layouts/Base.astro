---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'ima2-gen — Local Image Studio with Classic + Node Branching',
  description = 'Generate images locally with Classic mode, then branch the ones you love in a Node graph — palette, framing, and copy variants without losing the parent.',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteUrl = 'https://lidge-jun.github.io/ima2-gen/';
const ogImage = `${siteUrl}og.png`;
const faviconHref = `${base}/favicon.svg`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={siteUrl} />

    <meta property="og:title" content="ima2-gen — Branch the images you love" />
    <meta
      property="og:description"
      content="A local image studio with Classic + Node-graph branching. Run it with npx, keep every frame on your machine."
    />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/svg+xml" href={faviconHref} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Source+Serif+4:opsz,wght@8..60,400;8..60,500&family=IBM+Plex+Mono:wght@400;500&display=swap"
    />
  </head>
  <body>
    <slot />

  </body>
</html>
