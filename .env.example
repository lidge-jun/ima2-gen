# ima2-gen runtime configuration (see config.js)
# Copy to .env or export in your shell.

# HTTP port for the main server (alias: PORT)
IMA2_PORT=3333

# OAuth proxy subprocess port (openai-oauth)
OAUTH_PORT=10531

# Skip launching the openai-oauth subprocess (unit tests/CI)
# IMA2_NO_OAUTH_PROXY=1

# Config directory (defaults to ~/.ima2)
# IMA2_CONFIG_DIR=/custom/path

# Request body JSON limit
IMA2_BODY_LIMIT=50mb

# Max base64 length per reference image (bytes; decodes ~0.75x)
IMA2_MAX_REF_B64_BYTES=7340032

# In-flight job TTL (ms) — jobs older than this are reaped
IMA2_INFLIGHT_TTL_MS=600000

# Pino log level: trace|debug|info|warn|error|fatal
IMA2_LOG_LEVEL=info
